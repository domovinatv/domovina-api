# =============================================================================
# DOMOVINA-API — Coolify non-secret config overrides
#
# Ovo je deklarativni "config layer" koji scripts/coolify-env-merge.sh nanosi
# PREKO live Coolify env dumpa (.coolify-current.env). Cilj: držati ne-tajne
# config vrijednosti as-code, bez diranja secreta.
#
# ⚠️  NIKAD ne stavljaj secrete ovdje (JWT secret, postgres pass, anon/service
#     key, Google client secret, SMTP_PASS...). Oni žive samo u Coolifyju i
#     merge ih prolazi netaknute iz .coolify-current.env.
#
# Format:
#   KEY=VALUE
#   - scalar key  → zamijeni vrijednost u live env-u
#   - CSV_UNION key (vidi listu u coolify-env-merge.sh) → value su STAVKE koje
#     se OSIGURAJU prisutnima; postojeće live stavke se čuvaju, dodaju se samo
#     one koje fale (union, ne replace). Tako nikad ne izgubimo live redirecte.
# =============================================================================

# --- PostgREST schema exposure (CSV_UNION) -----------------------------------
# Bez domovina_ai PostgREST ne exposa watch_progress/favorites/handoff.
PGRST_DB_SCHEMAS=public,domovina_ai,storage,graphql_public

# --- Auth redirect allow-list (CSV_UNION) ------------------------------------
# Deep link za mobile/TV OAuth callback (ai.domovina://auth/callback).
# ⚠️ Upravljamo SAMO ADDITIONAL_REDIRECT_URLS. Coolify supabase compose mapira
#    GOTRUE_URI_ALLOW_LIST: '${ADDITIONAL_REDIRECT_URLS}' (vidi compose linija ~480),
#    pa je editable GOTRUE_URI_ALLOW_LIST ignoriran — ne diramo ga ovdje.
ADDITIONAL_REDIRECT_URLS=ai.domovina://auth/callback

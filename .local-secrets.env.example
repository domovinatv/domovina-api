# =============================================================================
# .local-secrets.env  (gitignored — copy to .local-secrets.env i popuni)
# =============================================================================
# Drži secrets koji se ne mogu generirati offline (vanjski servisi).
# scripts/build-coolify-env.sh čita ovaj file i ubacuje vrijednosti u finalni
# env block koji ide u clipboard.
#
# Sve vrijednosti ovdje OVERRIDE-aju Coolify defaults i generated secrets.
# =============================================================================

# Resend SMTP API key
# Generiraj: Resend dashboard → API Keys → Create API Key
# Permissions: "Sending access" (samo za domovina.ai domain)
SMTP_PASS=

# OpenAI (opcionalno — koristi se za Edge Functions / AI features)
OPENAI_API_KEY=

# Anthropic (opcionalno)
ANTHROPIC_API_KEY=

# === Coolify API (za programatske env/restart operacije) ===
# Token generiraj: https://app.domovina.link/security/api-tokens
# Permissions: Read + Write (treba i za restart/deploy)
# ⚠️ Coolify tokens sadrže `|` znak — UVIJEK pod navodnike ("..."), inače
#    shell ga interpretira kao pipe i `. .local-secrets.env` puca.
COOLIFY_API_URL=https://app.domovina.link
COOLIFY_API_TOKEN=""
COOLIFY_SERVICE_UUID=cv887vonujh1swebndh4x4iu

# === DB migration via SSH + docker exec ===
# SSH access do Coolify hosta
COOLIFY_SSH_HOST=ubuntu@89.168.100.120
COOLIFY_SSH_KEY=~/.ssh/dom-001-oracle-ssh-key-2026-04-20.key

# (Opcionalno) Eksplicitan container name. Ako prazno, scripts auto-detect-aju
# preko: docker ps | grep '^supabase-db-' (uzima prvi match).
COOLIFY_DB_CONTAINER=

# (Opcionalno) DB user/db unutar containera. Default je postgres/postgres.
COOLIFY_DB_USER=postgres
COOLIFY_DB_NAME=postgres

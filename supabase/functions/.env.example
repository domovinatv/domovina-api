# Lokalni secreti za edge funkcije (auto-učitava supabase CLI u edge container
# pri `supabase start`). GITIGNORIRAN — ne commitati. Vidi .env.example.
#
# SUPABASE_URL / ANON_KEY / SERVICE_ROLE_KEY NE stavljati — CLI ih auto-injektira.

# --- youtube-claim (channel ownership) ---
# Dedicirani Google OAuth client iz ZASEBNOG GCP projekta `domovina-creators`
# (NE iz `domovina-auth` gdje je GoTrue Google login — Princip D / D-bis: sensitive
# youtube.readonly scope ima vlastiti consent screen + verifikaciju, izoliran od
# login projekta). Enable YouTube Data API v3 u `domovina-creators`. Ispuni ovdje:
YOUTUBE_CLAIM_GOOGLE_CLIENT_ID=
YOUTUBE_CLAIM_GOOGLE_CLIENT_SECRET=
# Lokalni Flutter web trči na :5173 (vidi scripts/run-local.sh u domovina.ai).
YOUTUBE_CLAIM_REDIRECT_URI=http://localhost:5173/youtube-claim/callback

# --- safe-owner-add ---
# Prazno = stub safe_tx_hash (lokalni rad bez on-chaina). Postavi tek za realni
# Safe Transaction Service.
SAFE_TX_SERVICE_URL=

# --- certilia (eID login + KYC bridge) ---
# Edge fn `certilia` verificira Certilia idToken vs JWKS i upsert-a GoTrue usera.
# CERTILIA_ISSUER = baza za OIDC discovery (discovery.issuer se koristi za jwtVerify).
# KYC_ENCRYPTION_KEY = pgcrypto ključ za enkripciju OIB-a u identity_verifications.
# Vrijednosti u .local-secrets.env (jedini izvor istine).
CERTILIA_CLIENT_ID=
CERTILIA_ISSUER=
KYC_ENCRYPTION_KEY=

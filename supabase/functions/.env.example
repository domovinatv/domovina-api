# Lokalni secreti za edge funkcije (auto-učitava supabase CLI u edge container
# pri `supabase start`). GITIGNORIRAN — ne commitati. Vidi .env.example.
#
# SUPABASE_URL / ANON_KEY / SERVICE_ROLE_KEY NE stavljati — CLI ih auto-injektira.

# --- youtube-claim (channel ownership) ---
# Dedicirani Google OAuth client (NE GoTrue Google login client — Princip D).
# Kreiraj u Google Cloud Console → ispuni ovdje:
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Lokalni Flutter web trči na :5173 (vidi scripts/run-local.sh u domovina.ai).
YOUTUBE_CLAIM_REDIRECT_URI=http://localhost:5173/youtube-claim/callback

# --- safe-owner-add ---
# Prazno = stub safe_tx_hash (lokalni rad bez on-chaina). Postavi tek za realni
# Safe Transaction Service.
SAFE_TX_SERVICE_URL=
